# MongoDB Configuration
# Use a local MongoDB instance or MongoDB Atlas connection string.
# Example Atlas URI:
# MONGO=mongodb+srv://<username>:<password>@cluster0.mongodb.net/women-safety-app?retryWrites=true&w=majority
MONGO=mongodb://localhost:27017/women-safety-app

# Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:5173
JWT_SECRET_KEY=your_jwt_secret_here

# Email Configuration (Optional - for email notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# RapidAPI Configuration (Optional - for news and tutorials)
RAPID_API_KEY=your_rapid_api_key_here
